{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "node_modules/.tmp-tests",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": false,
    "sourceMap": false,
    "incremental": false
  },
  "include": [
    "tests/**/*.ts",
    "src/lib/admin-endpoint-guards.ts",
