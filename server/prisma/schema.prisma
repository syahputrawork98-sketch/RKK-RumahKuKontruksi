generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id             String    @id @default(cuid())
  userId         String?   @map("user_id")
  customerType   String    @map("customer_type")
  name           String?
  email          String?
  phone          String?
  avatar         String?
  address        String?
  identityNumber String?   @map("identity_number")
  occupation     String?
  companyName    String?   @map("company_name")
  picName        String?   @map("pic_name")
  picPosition    String?   @map("pic_position")
  logo           String?
  taxNumber      String?   @map("tax_number")
  businessField  String?   @map("business_field")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  projects       Project[]

  @@map("customers")
}

model Project {
  id                    String         @id @default(cuid())
  projectCode           String         @unique @map("project_code")
  name                  String
  type                  String
  status                String
  progress              Int            @default(0)
  customerId            String         @map("customer_id")
  location              String?
  startDate             DateTime?      @map("start_date")
  estimatedEndDate      DateTime?      @map("estimated_end_date")
  budgetTotal           Decimal        @default(0) @map("budget_total") @db.Decimal(15, 2)
  paidAmount            Decimal        @default(0) @map("paid_amount") @db.Decimal(15, 2)
  remainingAmount       Decimal        @default(0) @map("remaining_amount") @db.Decimal(15, 2)
  heroImage             String?        @map("hero_image")
  sourceDesignRequestId String?        @map("source_design_request_id")
  adminId               String?        @map("admin_id")
  supervisorId          String?        @map("supervisor_id")
  foremanId             String?        @map("foreman_id")
  verifiedProgress      Float          @default(0) @map("verified_progress")
  verifiedProgressUpdatedAt DateTime?  @map("verified_progress_updated_at")
  verifiedProgressById  String?        @map("verified_progress_by_id")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  stages                ProjectStage[]
  admin                 Admin?         @relation(fields: [adminId], references: [id])
  customer              Customer       @relation(fields: [customerId], references: [id])
  supervisor            Supervisor?    @relation(fields: [supervisorId], references: [id])
  foreman               Foreman?       @relation(fields: [foremanId], references: [id])
  rabCategories         RabCategory[]
  rabItems              RabItem[]
  rabPlans              RabPlan[]
  materialRequests      MaterialRequest[]
  progressLogs          ProgressVerificationLog[]

  @@map("projects")
}

model Supervisor {
  id                 String                  @id @default(cuid())
  name               String
  email              String?                 @unique
  phone              String?
  avatar             String?
  specialization     String?
  bio                String?
  city               String?
  status             String                  @default("active")
  maxProjectCapacity Int                     @default(3) @map("max_project_capacity")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")
  deletedAt          DateTime?               @map("deleted_at")
  certificates       SupervisorCertificate[]
  experiences        SupervisorExperience[]
  projects           Project[]
  materialRequests   MaterialRequest[]
  progressLogs       ProgressVerificationLog[]

  @@map("supervisors")
}

model SupervisorCertificate {
  id                String     @id @default(cuid())
  supervisorId      String     @map("supervisor_id")
  title             String
  issuer            String
  certificateNumber String?    @map("certificate_number")
  issuedAt          DateTime?  @map("issued_at")
  expiredAt         DateTime?  @map("expired_at")
  fileUrl           String?    @map("file_url")
  fileType          String?    @map("file_type")
  status             String     @default("valid")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  deletedAt         DateTime?  @map("deleted_at")
  supervisor        Supervisor @relation(fields: [supervisorId], references: [id])

  @@map("supervisor_certificates")
}

model SupervisorExperience {
  id           String     @id @default(cuid())
  supervisorId String     @map("supervisor_id")
  projectName  String     @map("project_name")
  companyName  String?    @map("company_name")
  role         String?
  location     String?
  startYear    Int?       @map("start_year")
  endYear      Int?       @map("end_year")
  description  String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id])

  @@map("supervisor_experiences")
}

model Foreman {
  id                 String               @id @default(cuid())
  userId             String?              @map("user_id")
  name               String
  email              String?              @unique
  phone              String?
  avatar             String?
  vendorType         String?              @map("vendor_type")
  companyName        String?              @map("company_name")
  address            String?
  specialization     String?
  experienceYears    Int?                 @map("experience_years")
  skillTags          Json?                @map("skill_tags")
  teamSummary        Json?                @map("team_summary")
  maxProjectCapacity Int                  @default(2) @map("max_project_capacity")
  status             String               @default("active")
  joinedAt           DateTime?            @map("joined_at")
  notes              String?
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  deletedAt          DateTime?            @map("deleted_at")
  certificates       ForemanCertificate[]
  experiences        ForemanExperience[]
  projects           Project[]
  materialRequests   MaterialRequest[]

  @@map("foremen")
}

model ForemanCertificate {
  id                String    @id @default(cuid())
  foremanId         String    @map("foreman_id")
  title             String
  issuer            String
  certificateNumber String?   @map("certificate_number")
  issuedAt          DateTime? @map("issued_at")
  expiredAt         DateTime? @map("expired_at")
  fileUrl           String?   @map("file_url")
  fileType          String?   @map("file_type")
  status            String    @default("valid")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  foreman           Foreman   @relation(fields: [foremanId], references: [id])

  @@map("foreman_certificates")
}

model ForemanExperience {
  id          String    @id @default(cuid())
  foremanId   String    @map("foreman_id")
  projectName String    @map("project_name")
  companyName String?   @map("company_name")
  role        String?
  location    String?
  startYear   Int?      @map("start_year")
  endYear     Int?      @map("end_year")
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  foreman     Foreman   @relation(fields: [foremanId], references: [id])

  @@map("foreman_experiences")
}

model ProjectStage {
  id           String    @id @default(cuid())
  projectId    String    @map("project_id")
  rabPlanId    String?   @map("rab_plan_id")
  categoryId   String?   @map("category_id")
  code         String
  title        String
  description  String?
  week         Int?
  status       String
  progress     Int       @default(0)
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  durationDays Int?      @map("duration_days")
  order        Int       @default(0)
  note         String?
  isVerified   Boolean   @default(false) @map("is_verified")
  verifiedBy   String?   @map("verified_by")
  verifiedAt   DateTime? @map("verified_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  project      Project   @relation(fields: [projectId], references: [id])
  materialRequests MaterialRequest[]

  @@map("project_stages")
}

model RabPlan {
  id                    String        @id @default(cuid())
  projectId             String        @map("project_id")
  title                 String
  type                  String
  version               String?
  status                String
  totalAmount           Decimal       @default(0) @map("total_amount") @db.Decimal(15, 2)
  notes                 String?
  sourceDesignRequestId String?       @map("source_design_request_id")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  approvedAt            DateTime?     @map("approved_at")
  categories            RabCategory[]
  items                 RabItem[]
  project               Project       @relation(fields: [projectId], references: [id])

  @@map("rab_plans")
}

model RabCategory {
  id          String    @id @default(cuid())
  rabPlanId   String    @map("rab_plan_id")
  projectId   String    @map("project_id")
  code        String
  name        String
  description String?
  order       Int       @default(0)
  subtotal    Decimal   @default(0) @db.Decimal(15, 2)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  project     Project   @relation(fields: [projectId], references: [id])
  rabPlan     RabPlan   @relation(fields: [rabPlanId], references: [id])
  items       RabItem[]

  @@map("rab_categories")
}

model RabItem {
  id             String      @id @default(cuid())
  rabPlanId      String      @map("rab_plan_id")
  categoryId     String      @map("category_id")
  projectId      String      @map("project_id")
  description    String
  location       String?
  volume         Decimal     @db.Decimal(12, 3)
  unit           String
  unitPrice      Decimal     @map("unit_price") @db.Decimal(15, 2)
  total          Decimal     @db.Decimal(15, 2)
  progress       Int         @default(0)
  completedValue Decimal     @default(0) @map("completed_value") @db.Decimal(15, 2)
  status         String
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  category       RabCategory @relation(fields: [categoryId], references: [id])
  project        Project     @relation(fields: [projectId], references: [id])
  rabPlan        RabPlan     @relation(fields: [rabPlanId], references: [id])
  materialRequestItems MaterialRequestItem[]

  @@map("rab_items")
}

model Architect {
  id                String                 @id @default(cuid())
  userId            String?                @map("user_id")
  name              String
  email             String?                @unique
  phone             String?
  avatar            String?
  employmentType    String?                @map("employment_type")
  specialization    String?
  experienceYears   Int?                   @map("experience_years")
  skillTags         Json?                  @map("skill_tags")
  maxDesignCapacity Int                    @default(2) @map("max_design_capacity")
  status            String                 @default("active")
  joinedAt          DateTime?              @map("joined_at")
  notes             String?
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  deletedAt         DateTime?              @map("deleted_at")
  certificates      ArchitectCertificate[]
  experiences       ArchitectExperience[]

  @@map("architects")
}

model ArchitectCertificate {
  id                String    @id @default(cuid())
  architectId       String    @map("architect_id")
  title             String
  issuer            String
  certificateNumber String?   @map("certificate_number")
  issuedAt          DateTime? @map("issued_at")
  expiredAt         DateTime? @map("expired_at")
  fileUrl           String?   @map("file_url")
  fileType          String?   @map("file_type")
  status            String    @default("valid")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  architect         Architect @relation(fields: [architectId], references: [id])

  @@map("architect_certificates")
}

model ArchitectExperience {
  id          String    @id @default(cuid())
  architectId String    @map("architect_id")
  projectName String    @map("project_name")
  companyName String?   @map("company_name")
  role        String?
  location    String?
  startYear   Int?      @map("start_year")
  endYear     Int?      @map("end_year")
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  architect   Architect @relation(fields: [architectId], references: [id])

  @@map("architect_experiences")
}

model Admin {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  phone     String?
  avatar    String?
  status    String    @default("active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  projects  Project[]
  materialRequests MaterialRequest[]

  @@map("admins")
}

model Superadmin {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  phone     String?
  avatar    String?
  status    String    @default("active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("superadmins")
}

model MaterialRequest {
  id                 String                   @id @default(cuid())
  requestCode        String                   @unique @map("request_code")
  projectId          String                   @map("project_id")
  stageId            String                   @map("stage_id")
  foremanId          String                   @map("foreman_id")
  supervisorId       String                   @map("supervisor_id")
  adminId            String?                  @map("admin_id")
  status             String                   @default("draft")
  priority           String                   @default("medium")
  neededDate         DateTime?                @map("needed_date")
  reason             String?
  overEstimateReason String?                  @map("over_estimate_reason")
  supervisorNote     String?                  @map("supervisor_note")
  adminNote          String?                  @map("admin_note")
  rejectionReason    String?                  @map("rejection_reason")
  revisionNote       String?                  @map("revision_note")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  submittedAt        DateTime?                @map("submitted_at")
  supervisorReviewedAt DateTime?              @map("supervisor_reviewed_at")
  adminReviewedAt    DateTime?                @map("admin_reviewed_at")
  processedAt        DateTime?                @map("processed_at")
  deliveredAt        DateTime?                @map("delivered_at")
  receivedAt         DateTime?                @map("received_at")
  completedAt        DateTime?                @map("completed_at")
  cancelledAt        DateTime?                @map("cancelled_at")

  project            Project                  @relation(fields: [projectId], references: [id])
  stage              ProjectStage             @relation(fields: [stageId], references: [id])
  foreman            Foreman                  @relation(fields: [foremanId], references: [id])
  supervisor         Supervisor               @relation(fields: [supervisorId], references: [id])
  admin              Admin?                   @relation(fields: [adminId], references: [id])
  items              MaterialRequestItem[]
  history            MaterialRequestHistory[]

  @@map("material_requests")
}

model MaterialRequestItem {
  id                      String          @id @default(cuid())
  materialRequestId       String          @map("material_request_id")
  rabItemId               String?         @map("rab_item_id")
  materialName            String          @map("material_name")
  requestedQty            Decimal         @map("requested_qty") @db.Decimal(12, 3)
  approvedQty             Decimal?        @map("approved_qty") @db.Decimal(12, 3)
  receivedQty             Decimal?        @map("received_qty") @db.Decimal(12, 3)
  unit                    String
  estimatedQtyFromRab     Decimal?        @map("estimated_qty_from_rab") @db.Decimal(12, 3)
  previouslyRequestedQty  Decimal?        @map("previously_requested_qty") @db.Decimal(12, 3)
  previouslyApprovedQty   Decimal?        @map("previously_approved_qty") @db.Decimal(12, 3)
  previouslyReceivedQty   Decimal?        @map("previously_received_qty") @db.Decimal(12, 3)
  totalAfterRequestQty    Decimal?        @map("total_after_request_qty") @db.Decimal(12, 3)
  varianceQty             Decimal?        @map("variance_qty") @db.Decimal(12, 3)
  variancePercentage      Decimal?        @map("variance_percentage") @db.Decimal(8, 2)
  toleranceStatus         String?         @map("tolerance_status")
  estimatedUnitPrice      Decimal?        @map("estimated_unit_price") @db.Decimal(15, 2)
  finalUnitPrice          Decimal?        @map("final_unit_price") @db.Decimal(15, 2)
  note                    String?
  isAdditionalMaterial    Boolean         @default(false) @map("is_additional_material")
  additionalReason        String?         @map("additional_reason")

  materialRequest         MaterialRequest @relation(fields: [materialRequestId], references: [id])
  rabItem                 RabItem?        @relation(fields: [rabItemId], references: [id])

  @@map("material_request_items")
}

model MaterialRequestHistory {
  id                String          @id @default(cuid())
  materialRequestId String          @map("material_request_id")
  action            String
  oldStatus         String?         @map("old_status")
  newStatus         String?         @map("new_status")
  actorId           String          @map("actor_id")
  actorRole         String          @map("actor_role")
  note              String?
  createdAt         DateTime        @default(now()) @map("created_at")

  materialRequest   MaterialRequest @relation(fields: [materialRequestId], references: [id])

  @@map("material_request_history")
}

model ProgressVerificationLog {
  id String @id @default(cuid())

  projectId String @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  supervisorId String @map("supervisor_id")
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id])

  previousProgress Float @map("previous_progress")
  newProgress      Float @map("new_progress")
  notes            String

  stageId String? @map("stage_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("progress_verification_logs")
}
